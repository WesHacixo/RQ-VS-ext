  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#662222",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": ["keyword.control", "constant.other.color"],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": ["entity.other.attribute-name", "entity.name.tag"],
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "variable.function"],
      "settings": {
        "foreground": "#ff4444"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": ["string", "constant.other.symbol", "constant.other.key"],
      "settings": {
        "foreground": "#ff4444"
      }
    },
    {
      "scope": ["meta.property-name", "variable.other.property"],
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "scope": ["variable.parameter.function"],
      "settings": {
        "foreground": "#ff4444"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#ff4444"
      }
    },
    {
      "scope": ["meta.brace"],
      "settings": {
        "foreground": "#ff4444"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#ff0000",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.underline"],
      "settings": {
        "textDecoration": "underline"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#662222",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": {
        "foreground": "#ff4444"
      }
    },
    {
      "scope": ["string.other.link"],
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "scope": ["meta.selector"],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": ["entity.name.tag.css"],
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#ff4444"
      }
    },
    {
      "scope": ["constant.numeric.css"],
      "settings": {
        "foreground": "#ff6666"
      }
    }
  ]
}
