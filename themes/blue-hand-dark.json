  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5c6773",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#b084eb"
      }
    },
    {
      "scope": ["keyword.control", "constant.other.color"],
      "settings": {
        "foreground": "#b084eb"
      }
    },
    {
      "scope": ["entity.other.attribute-name", "entity.name.tag"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "variable.function"],
      "settings": {
        "foreground": "#4f7cac"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "scope": ["string", "constant.other.symbol", "constant.other.key"],
      "settings": {
        "foreground": "#7eb069"
      }
    },
    {
      "scope": ["meta.property-name", "variable.other.property"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "scope": ["variable.parameter.function"],
      "settings": {
        "foreground": "#e1e5f2"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
      "scope": ["meta.brace"],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#e06c75",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.underline"],
      "settings": {
        "textDecoration": "underline"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#5c6773",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": {
        "foreground": "#7eb069"
      }
    },
    {
      "scope": ["string.other.link"],
      "settings": {
        "foreground": "#4f7cac"
      }
    },
    {
      "scope": ["meta.selector"],
      "settings": {
        "foreground": "#b084eb"
      }
    },
    {
      "scope": ["entity.name.tag.css"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#e1e5f2"
      }
    },
    {
      "scope": ["constant.numeric.css"],
      "settings": {
        "foreground": "#d19a66"
      }
    }
  ]
}
