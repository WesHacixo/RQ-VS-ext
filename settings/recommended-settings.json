{
  "// VS Blue Recommended Settings": "Optimized for Blue-Hand theme and performance",
  
  "// Theme and Appearance": "",
  "workbench.colorTheme": "Blue-Hand Dark",
  "workbench.iconTheme": "vs-minimal",
  "workbench.productIconTheme": "fluent-icons",
  
  "// Font Configuration": "",
  "editor.fontFamily": "'Inter Rounded', 'Nunito Sans', 'Atkinson Hyperlegible', 'SF Mono', Consolas, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.fontWeight": "400",
  "editor.lineHeight": 1.6,
  "editor.letterSpacing": 0.5,
  "terminal.integrated.fontFamily": "'Inter Rounded', 'SF Mono', Consolas, monospace",
  "terminal.integrated.fontSize": 13,
  
  "// Performance Optimizations": "",
  "editor.minimap.enabled": false,
  "editor.smoothScrolling": false,
  "workbench.list.smoothScrolling": false,
  "workbench.reduceMotion": "on",
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.occurrencesHighlight": true,
  "editor.selectionHighlight": true,
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 120,
  
  "// Canvas Layout Enhancements": "",
  "workbench.editor.showTabs": true,
  "workbench.editor.tabCloseButton": "right",
  "workbench.editor.tabSizing": "fit",
  "workbench.activityBar.visible": true,
  "workbench.statusBar.visible": true,
  "workbench.sideBar.location": "left",
  "workbench.panel.defaultLocation": "bottom",
  
  "// File Management": "",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/.cache/**": true,
    "**/coverage/**": true,
    "**/.nyc_output/**": true
  },
  
  "// Search Optimizations": "",
  "search.followSymlinks": false,
  "search.smartCase": true,
  "search.useGlobalIgnoreFiles": true,
  "search.useParentIgnoreFiles": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true
  },
  
  "// Extension Management": "",
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,
  "extensions.ignoreRecommendations": false,
  
  "// Terminal Configuration": "",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.shell.osx": "/bin/zsh",
  "terminal.integrated.env.osx": {
    "VS_BLUE_ACTIVE": "true"
  },
  
  "// Language-Specific Settings": "",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": true
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": true
    }
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    }
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  
  "// Git Integration": "",
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.decorations.enabled": true,
  "scm.diffDecorations": "all",
  
  "// IntelliSense and Suggestions": "",
  "editor.suggest.insertMode": "replace",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.parameterHints.enabled": true,
  "editor.hover.enabled": true,
  "editor.lightbulb.enabled": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  
  "// Bracket Pair Colorization": "",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.bracketPairsHorizontal": "active",
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.indentation": true,
  
  "// Workspace Trust": "",
  "security.workspace.trust.untrustedFiles": "prompt",
  "security.workspace.trust.banner": "never",
  "security.workspace.trust.startupPrompt": "once",
  
  "// VS Blue Specific Settings": "",
  "vsblue.metricsHUD.enabled": false,
  "vsblue.imfOverlays.enabled": false,
  "vsblue.performance.mbpOptimized": true,
  "vsblue.canvas.fluidLayout": true,
  "vsblue.redcode.threshold": 85,
  "vsblue.fonts.rounded": true,
  
  "// Telemetry": "",
  "telemetry.telemetryLevel": "off",
  "workbench.enableExperiments": false,
  
  "// Zen Mode": "",
  "zenMode.centerLayout": false,
  "zenMode.fullScreen": false,
  "zenMode.hideActivityBar": false,
  "zenMode.hideStatusBar": false,
  "zenMode.hideTabs": false,
  "zenMode.restore": true,
  
  "// Breadcrumbs": "",
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "on",
  "breadcrumbs.symbolPath": "on",
  
  "// Problems Panel": "",
  "problems.decorations.enabled": true,
  "problems.showCurrentInStatus": true,
  
  "// Debug Configuration": "",
  "debug.console.fontSize": 13,
  "debug.console.fontFamily": "'Inter Rounded', 'SF Mono', Consolas, monospace",
  "debug.inlineValues": "auto",
  "debug.showBreakpointsInOverviewRuler": true
}
