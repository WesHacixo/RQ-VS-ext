{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "node",
        "typeRoots": ["node_modules/@types"],
        "jsx": "react-jsx",
        "types": ["react", "react-dom", "mocha"]
    },
    "exclude": [
        "node_modules",
        ".vscode-test",
        "__tests__",
        "fixtures"
    ],
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx"
    ]
}
